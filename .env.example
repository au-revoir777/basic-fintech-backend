APP_NAME=Finance Dashboard API
API_V1_PREFIX=/api/v1

# Database Configuration
# For development: SQLite (file-based)
DATABASE_URL=sqlite:///./finance.db
# For testing: In-memory SQLite
# DATABASE_URL=sqlite:///:memory:
# For production: PostgreSQL
# DATABASE_URL=postgresql://user:password@localhost/dbname

# JWT Configuration (REQUIRED - change in production)
JWT_SECRET_KEY=change-me-super-secret-key-at-least-32-characters-long
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS Configuration (comma-separated URLs)
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# Rate Limiting
RATE_LIMIT_PER_MINUTE=120
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15
